NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Used for magic links and OAuth redirect URLs when the app is not opened in a browser
# (e.g. email clients). Must match a URL in Supabase Auth → URL configuration → Redirect URLs.
# Example: https://your-domain.vercel.app
NEXT_PUBLIC_SITE_URL=

# Optional: override default bucket id `portfolio-media` (must match Supabase Storage bucket)
NEXT_PUBLIC_STORAGE_BUCKET=

# Set automatically on Vercel; optional locally for analytics page hints
NEXT_PUBLIC_VERCEL_PROJECT_PRODUCTION_URL=
